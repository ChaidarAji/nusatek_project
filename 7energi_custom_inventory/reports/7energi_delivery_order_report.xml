<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data>

    <!-- A4 paperformat, normal margins -->
    <record id="paperformat_7energi_delivery_order" model="report.paperformat">
      <field name="name">7Energi Delivery Order (A4)</field>
      <field name="default" eval="False"/>
      <field name="format">A4</field>
      <field name="orientation">Portrait</field>
      <field name="margin_top">10</field>
      <field name="margin_bottom">10</field>
      <field name="margin_left">10</field>
      <field name="margin_right">10</field>
      <field name="header_line" eval="False"/>
      <field name="dpi">90</field>
    </record>

    <!-- Report action: shows under Print on stock.picking -->
    <record id="action_report_7energi_delivery_order" model="ir.actions.report">
      <field name="name">7Energi Delivery Order</field>
      <field name="model">stock.picking</field>
      <field name="report_type">qweb-pdf</field>
      <field name="report_name">7energi_custom_inventory.report_7energi_delivery_order_document</field>
      <field name="report_file">7energi_custom_inventory.report_7energi_delivery_order_document</field>
      <field name="paperformat_id" ref="7energi_custom_inventory.paperformat_7energi_delivery_order"/>
      <field name="binding_model_id" eval="False"/>
      <field name="print_report_name">'DELIVERY ORDER - %s' % (object.name)</field>
    </record>

    <!-- Main report template -->
    <template id="report_7energi_delivery_order_document">
      <t t-call="web.basic_layout">
        <t t-foreach="docs" t-as="o">
          <t t-set="company" t-value="o.company_id"/>

          <div class="page">
            <style type="text/css">
              /* Keep Odoo default fonts; only control borders/spacing */
              table.do-doc { width: 100%; border-collapse: collapse; font-size: 9pt; }
              table.do-doc thead { display: table-header-group; }
              table.do-doc tfoot { display: table-footer-group; }

              /* default cell borders (thick like sample printout) */
              table.do-doc th, table.do-doc td { border: 2px solid #000; padding: 2px 4px; vertical-align: top; }

              /* HEADER area rows: no border like the sample top area */
              tr.do-top td { border: 0 !important; padding: 0 !important; }

              .do-title { text-align: center; font-weight: 700; font-size: 14pt; margin: 6px 0 8px; letter-spacing: 0.5px; }
              .do-head-wrap { width: 100%; border-collapse: collapse; }
              .do-head-wrap td { border: 0 !important; padding: 0 !important; vertical-align: top; }

              .do-left { width: 60%; }
              .do-right { width: 40%; }

              .do-logo { height: 28px; margin-bottom: 4px; }
              .do-recipient { font-size: 9pt; line-height: 1.25; }
              .do-recipient .lbl { font-weight: 700; }

              .do-no { text-align: right; font-size: 10pt; font-weight: 700; margin-bottom: 2px; }
              table.do-meta { width: 100%; border-collapse: collapse; font-size: 9pt; }
              table.do-meta td { border: 0 !important; padding: 0 !important; }
              .meta-lbl { width: 70px; font-weight: 700; }
              .meta-colon { width: 10px; text-align: center; }

              /* Column sizes */
              .col-no   { width: 26px; text-align: center; }
              .col-desc { width: 46%; }
              .col-code { width: 16%; text-align: center; }
              .col-qty  { width: 8%; text-align: center; }
              .col-uom  { width: 10%; text-align: center; }
              .col-note { width: 20%; }

              thead .colhdr th { text-align: center; font-weight: 700; }

              tr.is-section td { font-weight: 700; }
              tr.is-sub td.col-desc { padding-left: 10px; }

              .ship-label { font-weight: 700; margin-top: 6px; }
              .ship-text { font-size: 9pt; line-height: 1.2; }

              table.sign { width: 100%; border-collapse: collapse; margin-top: 6px; font-size: 9pt; }
              table.sign th, table.sign td { border: 2px solid #000; padding: 2px 4px; }
              table.sign th { font-weight: 700; text-align: center; }

              .note { font-size: 8pt; margin-top: 3px; }
              .company-foot { font-size: 8pt; margin-top: 4px; }
              .footer { text-align: center; }
            </style>

            <table class="do-doc">

              <!-- HEADER (repeats each page if multi-page) -->
              <thead>
                <tr class="do-top">
                  <td colspan="6">
                    <div class="do-title">DELIVERY ORDER</div>

                    <table class="do-head-wrap">
                      <tr>
                        <!-- LEFT -->
                        <td class="do-left">
                          <div>
                            <img t-if="company.logo" t-att-src="image_data_uri(company.logo)" alt="Logo" style="max-height:60px; max-width:60px; vertical-align:middle; margin-right:15px;"/>
                          </div>

                          <div class="do-recipient">
                            <div class="lbl">KEPADA YTH,</div>

                            <!-- Delivery address -->
                            <div><t t-esc="o.partner_id.name or ''"/></div>
                            <t t-if="o.partner_id.street"><div><t t-esc="o.partner_id.street"/></div></t>
                            <t t-if="o.partner_id.street2"><div><t t-esc="o.partner_id.street2"/></div></t>

                            <t t-if="o.partner_id.city or o.partner_id.state_id or o.partner_id.zip">
                              <div>
                                <t t-esc="o.partner_id.city or ''"/>
                                <t t-if="o.partner_id.state_id">, <t t-esc="o.partner_id.state_id.name"/></t>
                                <t t-if="o.partner_id.zip"> <t t-esc="o.partner_id.zip"/></t>
                              </div>
                            </t>

                            <t t-if="o.partner_id.country_id">
                              <div><t t-esc="o.partner_id.country_id.name"/></div>
                            </t>

                          </div>
                        </td>

                        <!-- RIGHT -->
                        <td class="do-right">
                          <table class="do-meta">
                            <tr>
                              <td class="meta-lbl">No.</td><td class="meta-colon">:</td>
                              <td><t t-esc="o.name or ''"/></td>
                            </tr>
                            <tr>
                              <td class="meta-lbl">PROYEK</td><td class="meta-colon">:</td>
                              <td><t t-esc="o.project or ''"/></td>
                            </tr>
                            <tr>
                              <td class="meta-lbl">ID PAKET</td><td class="meta-colon">:</td>
                              <td><t t-esc="o.package or ''"/></td>
                            </tr>
                            <tr>
                              <td class="meta-lbl">GUDANG</td><td class="meta-colon">:</td>
                              <td>
                                <t t-esc="(o.picking_type_id.warehouse_id.name if o.picking_type_id and o.picking_type_id.warehouse_id else '')"/>
                              </td>
                            </tr>
                            <tr>
                              <td class="meta-lbl">TANGGAL</td><td class="meta-colon">:</td>
                              <td>
                                <t t-if="o.scheduled_date">
                                  <span t-field="o.scheduled_date" t-options='{"widget":"date","format":"dd MMMM y"}'/>
                                </t>
                              </td>
                            </tr>
                          </table>
                        </td>
                      </tr>
                    </table>

                  </td>
                </tr>

                <!-- COLUMN HEADERS (repeat each page) -->
                <tr class="colhdr">
                  <th class="col-no" rowspan="2">No</th>
                  <th class="col-desc" rowspan="2">Description</th>
                  <th colspan="3">Keterangan</th>
                  <th class="col-note" rowspan="2">KETERANGAN</th>
                </tr>
                <tr class="colhdr">
                  <th class="col-code">KODE BARANG</th>
                  <th class="col-qty">QTY</th>
                  <th class="col-uom">Satuan</th>
                </tr>
              </thead>

              <!-- BODY LINES -->
              <tbody>
                <t t-set="line_no" t-value="0"/>
                <t t-set="lines" t-value="o._get_7energi_do_lines()"/>

                <t t-foreach="lines" t-as="l">
                  <!-- MAIN (auto increment) -->
                  <t t-if="l.get('type') == 'main'">
                    <t t-set="line_no" t-value="line_no + 1"/>
                    <t t-set="qty_print" t-value="l.get('qty') or 0"/>
                    <t t-if="l.get('is_section_header')">
                      <t t-set="qty_print" t-value="''"/>
                      <tr>
                        <td class="col-no">&#160;</td>
                        <td class="col-desc">&#160;</td>
                        <td class="col-code">&#160;</td>
                        <td class="col-qty">&#160;</td>
                        <td class="col-uom">&#160;</td>
                        <td class="col-note">&#160;</td>
                      </tr>
                    </t>
                    <tr t-att-class="'is-section' if l.get('is_section_header') else ''">
                      <td class="col-no"><t t-esc="line_no"/></td>
                      <td class="col-desc"><t t-esc="l.get('description') or ''"/></td>
                      <td class="col-code"><t t-esc="l.get('code') or ''"/></td>
                      <td class="col-qty"><t t-esc="qty_print"/></td>
                      <td class="col-uom"><t t-esc="l.get('uom') or ''"/></td>
                      <td class="col-note"><t t-esc="l.get('note') or ''"/></td>
                    </tr>
                  </t>

                  <!-- SUB (no increment, dash) -->
                  <t t-elif="l.get('type') == 'sub'">
                    <tr class="is-sub">
                      <td class="col-no"></td>
                      <td class="col-desc">- <t t-esc="l.get('description') or ''"/></td>
                      <td class="col-code"><t t-esc="l.get('code') or ''"/></td>
                      <td class="col-qty"><t t-esc="l.get('qty') or 0"/></td>
                      <td class="col-uom"><t t-esc="l.get('uom') or ''"/></td>
                      <td class="col-note"><t t-esc="l.get('note') or ''"/></td>
                    </tr>
                  </t>
                </t>
              </tbody>
              </table>
            </div>
            <!-- /BODY -->

            <!-- NON-REPEATING SECTION -->
            <div class="ship-label">ALAMAT PENGIRIMAN :</div>
            <div class="ship-text">
              <t t-set="ship_note" t-value="o.note or ''"/>
              <t t-if="ship_note">
                <t t-esc="ship_note"/>
              </t>
            </div>

            <table class="sign">
              <tr>
                <th style="width:15%">DITERIMA OLEH,</th>
                <th style="width:15%">SECURITY</th>
                <th style="width:15%">SUPIR</th>
                <th style="width:15%">GUDANG</th>
                <th style="width:40%">HORMAT KAMI,</th>
              </tr>

              <!-- big signing area -->
              <tr style="height:80px;">
                <td></td>
                <td></td>
                <td></td>
                <td></td>
                <td></td>
              </tr>

              <!-- bottom strip row (company name has its own bordered line) -->
              <tr style="height:18px;">
                <td></td>
                <td></td>
                <td></td>
                <td></td>
                <td style="text-align:center; font-weight:700; vertical-align:middle;">
                  <t t-esc="company.name or ''"/>
                </td>
              </tr>
            </table>


            <div class="note">
              * Barang yang sudah dibeli tidak dapat ditukar atau dikembalikan
            </div>

            <!-- FOOTER (repeat every page) -->
            <div class="footer" style="text-align:center; font-size:8pt;">
              <div class="company-foot">
                <t t-if="company.partner_id">
                  <t t-esc="company.partner_id.contact_address or ''"/>
                  <t t-if="company.partner_id.phone"> | <t t-esc="company.partner_id.phone"/></t>
                </t>
              </div>
            </div>
            <!-- /FOOTER -->

          </t>
        </t>
    </template>


  </data>
</odoo>
